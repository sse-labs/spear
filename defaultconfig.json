{
  "profiling": {
    "min_program_energy": 1e-8,
    "min_instruction_energy": 1e-8,
    "cpu_regression": {
      "limit": 1000,
      "step": 50,
      "offset": 300
    },
    "syscalls": {
      "runtime": 60,
      "default_energy": 1e-6,
      "max_syscall_id": 462
    }
  },
  "analysis": {
    "type": "comparison",
    "clusteredCacheEnabled": true,
    "feasibilityEnabled": true,
    "writeDotFiles": false,
    "legacyConfig": {
      "mode": "program",
      "format": "json",
      "strategy": "worst"
    },
    "fallback": {
      "MALFORMED_LOOP":  1000,
      "SYMBOLIC_BOUND_LOOP":  2000,
      "NON_COUNTING_LOOP":  3000,
      "NESTED_LOOP":  4000,
      "UNKNOWN_LOOP": 5000
    }
  }
}